# --- LLM (required) ---
GROQ_API_KEY=gsk_...                 # llama-3.3-70b-versatile inference + RAGAS judge

# --- Vector Store ---
VECTOR_STORE_MODE=local              # local | pinecone
CHROMA_PERSIST_DIR=./chroma_db

# Pinecone (only required when VECTOR_STORE_MODE=pinecone — used for hosted demo)
PINECONE_API_KEY=
PINECONE_INDEX_NAME=sec-rag-intel

# --- Embeddings (local, no API key needed) ---
EMBEDDING_MODEL_NAME=BAAI/bge-small-en-v1.5

# --- SEC EDGAR ---
# SEC requires a User-Agent string identifying the requester
SEC_USER_AGENT="Your Name your.email@example.com"

# --- Groq free-tier guardrails (optional — sensible defaults in src/config.py) ---
# GROQ_DAILY_TOKEN_BUDGET=90000      # stop LLM calls before the ~100k/day tier is burned
# GROQ_DAILY_REQUEST_BUDGET=900      # under the 1k/day request limit
# GROQ_RPM_LIMIT=25                  # under the 30 req/min limit
# LLM_MAX_TOKENS=1024                # cap answer length per generation
# ANSWER_CACHE_ENABLED=true          # repeat questions cost 0 tokens

# --- App ---
LOG_LEVEL=INFO
