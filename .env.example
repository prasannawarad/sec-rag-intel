# --- LLM + Embeddings ---
OPENAI_API_KEY=sk-...                # text-embedding-3-small
GROQ_API_KEY=gsk_...                 # llama-3.3-70b-versatile inference

# --- Vector Store ---
VECTOR_STORE_MODE=local              # local | pinecone
CHROMA_PERSIST_DIR=./chroma_db

# Pinecone (only required when VECTOR_STORE_MODE=pinecone)
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=us-east-1-aws
PINECONE_INDEX_NAME=sec-rag-intel

# --- SEC EDGAR ---
# SEC requires a User-Agent string identifying the requester
SEC_USER_AGENT="Your Name your.email@example.com"

# --- App ---
LOG_LEVEL=INFO
